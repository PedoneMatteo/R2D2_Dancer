<?xml version="1.0"?>
<!--
    DANCING R2D2 - URDF Model
    ==========================
    This file describes the geometry and structure of the R2D2 robot.

    KEY CONCEPTS:
    - <link>:   a rigid part of the robot (body, head, leg...).
                It can have geometry (visual for RViz, collision for physics),
                mass (inertial) and color (material).
    - <joint>:  a connection between two links. It can be of various types:
                * "revolute" = rotation around an axis (hinge)
                * "continuous" = like revolute but without angle limits
                * "fixed" = fixed joint (no movement)
                * "prismatic" = translation along an axis
                <origin> defines the position/orientation of the joint.
                <axis> defines the rotation/translation axis.

    HOW TO USE WITH RViz:
    1. Run: ros2 launch r2d2_dancer r2d2_dancer.launch.py
    2. In RViz, add "RobotModel" and set "Description Topic" to /robot_description
    3. Add "TF" to see the reference frames
    4. You will see R2D2 moving to the beat!

    CREATIVE MODIFICATION:
    - Change the colors with RGBA values (around lines 80-90)
    - Add new links (e.g. antennas, lights, extendable arms)
    - Modify the oscillation frequencies in state_publisher.py
    - Experiment with different geometries: box, cylinder, sphere, mesh
-->
<robot name="r2d2">

    <!-- ============================================================
         MATERIALS (colors of the parts)
         RGBA: (Red, Green, Blue, Alpha) - values from 0.0 to 1.0
         ============================================================ -->
    <material name="r2d2_white">
        <color rgba="0.95 0.95 0.95 1.0"/>
    </material>
    <material name="r2d2_blue">
        <color rgba="0.1 0.3 0.8 1.0"/>
    </material>
    <material name="r2d2_silver">
        <color rgba="0.7 0.7 0.7 1.0"/>
    </material>
    <material name="r2d2_red">
        <color rgba="0.9 0.1 0.1 1.0"/>
    </material>


    <!-- ============================================================
         BASE LINK - is the starting point (root) of the robot
         The entire robot is built starting from here.
         In RViz, this link will be stationary.
         ============================================================ -->
    <link name="base_link">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <material name="r2d2_blue"/>
        </visual>
    </link>


    <!-- ============================================================
         BODY - Main cylinder of R2D2
         Connected to base_link with a FIXED joint (does not move on its own,
         but can be pushed by base_link if it were to move)
         ============================================================ -->
    <link name="body">
        <visual>
            <geometry>
                <!-- Cylinder: radius 0.25m, height 0.6m -->
                <cylinder radius="0.25" length="0.6"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="r2d2_white"/>
        </visual>
    </link>

    <!-- Joint between base_link and body -->
    <joint name="base_to_body" type="fixed">
        <parent link="base_link"/>
        <child link="body"/>
        <!-- The body is shifted upward by 0.3m (half height) -->
        <origin xyz="0 0 0.3" rpy="0 0 0"/>
    </joint>


    <!-- ============================================================
         HEAD - Half sphere (dome) on top of the body
         The joint is of type REVOLUTE: it rotates around the Z axis
         The head will rotate left/right with an oscillation
         ============================================================ -->
    <link name="head">
        <visual>
            <geometry>
                <!-- Flattened sphere: looks like a dome -->
                <sphere radius="0.22"/>
            </geometry>
            <origin xyz="0 0 -0.08" rpy="0 0 0"/>
            <material name="r2d2_silver"/>
        </visual>
    </link>

    <!-- joint_head: allows the head to rotate around Z (yaw) -->
    <joint name="joint_head" type="revolute">
        <parent link="body"/>
        <child link="head"/>
        <!-- Positioned on top of the body (0.3m = half body height) -->
        <origin xyz="0 0 0.3" rpy="0 0 0"/>
        <!-- Rotation axis: Z (blue in RViz) -->
        <axis xyz="0 0 1"/>
        <!-- Rotation limits: ±45 degrees (in radians) -->
        <limit lower="-0.8" upper="0.8" effort="10" velocity="10"/>
    </joint>


    <!-- ============================================================
         EYE (sensor/lens) on the head
         A small blue cylinder on the front part of the dome
         ============================================================ -->
    <link name="eye">
        <visual>
            <geometry>
                <cylinder radius="0.04" length="0.05"/>
            </geometry>
            <material name="r2d2_blue"/>
        </visual>
    </link>

    <joint name="head_to_eye" type="fixed">
        <parent link="head"/>
        <child link="eye"/>
        <!-- Protruding forward (y=0.15) on the dome -->
        <origin xyz="0.15 0 0.02" rpy="0 0 0"/>
    </joint>


    <!-- ============================================================
         LEFT LEG
         A cylinder that oscillates forward/backward as if R2D2 were dancing!
         The joint rotates around the Y axis (pitch).
         ============================================================ -->
    <link name="left_leg">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.35"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="r2d2_white"/>
        </visual>
    </link>

    <!-- joint_left_leg: forward/backward oscillation (around Y) -->
    <joint name="joint_left_leg" type="revolute">
        <parent link="body"/>
        <child link="left_leg"/>
        <!-- Attached to the bottom of the body, shifted to the left (y=-0.12) -->
        <origin xyz="0 -0.12 -0.3" rpy="0 0 0"/>
        <!-- Y axis: forward/backward rotation -->
        <axis xyz="0 1 0"/>
        <limit lower="-0.8" upper="0.8" effort="10" velocity="10"/>
    </joint>

    <!-- Left foot -->
    <link name="left_foot">
        <visual>
            <geometry>
                <box size="0.12 0.1 0.04"/>
            </geometry>
            <material name="r2d2_blue"/>
        </visual>
    </link>

    <joint name="left_leg_to_foot" type="fixed">
        <parent link="left_leg"/>
        <child link="left_foot"/>
        <!-- At the end of the leg (0.175 = half leg length) -->
        <origin xyz="0 0 -0.175" rpy="0 0 0"/>
    </joint>


    <!-- ============================================================
         RIGHT LEG
         Same structure as the left one, but oscillates in counter-phase
         (phase offset) to create the "dance" effect
         ============================================================ -->
    <link name="right_leg">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.35"/>
            </geometry>
            <material name="r2d2_white"/>
        </visual>
    </link>

    <joint name="joint_right_leg" type="revolute">
        <parent link="body"/>
        <child link="right_leg"/>
        <origin xyz="0 0.12 -0.3" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-0.8" upper="0.8" effort="10" velocity="10"/>
    </joint>

    <!-- Right foot -->
    <link name="right_foot">
        <visual>
            <geometry>
                <box size="0.12 0.1 0.04"/>
            </geometry>
            <material name="r2d2_blue"/>
        </visual>
    </link>

    <joint name="right_leg_to_foot" type="fixed">
        <parent link="right_leg"/>
        <child link="right_foot"/>
        <origin xyz="0 0 -0.175" rpy="0 0 0"/>
    </joint>


    <!-- ============================================================
         LEFT ARM
         A lateral arm that oscillates up/down.
         The rotation rpy="1.5708 0 0" (π/2 around X) makes it so
         that the box starts horizontal instead of vertical.
         ============================================================ -->
    <link name="left_arm">
        <visual>
            <geometry>
                <box size="0.08 0.08 0.3"/>
            </geometry>
            <!-- The box is shifted by 0.15 along Z (outward in the new orientation) -->
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <material name="r2d2_silver"/>
        </visual>
    </link>

    <joint name="joint_left_arm" type="revolute">
        <parent link="body"/>
        <child link="left_arm"/>
        <!-- Attached to the left side of the body.
             rpy="1.5708 0 0" rotates the frame by 90° around X:
             the arm extends horizontally to the left. -->
        <origin xyz="0 -0.25 0.05" rpy="1.5708 0 0"/>
        <!-- X axis: up/down oscillation -->
        <axis xyz="1 0 0"/>
        <limit lower="-1.0" upper="1.0" effort="10" velocity="10"/>
    </joint>


    <!-- ============================================================
         RIGHT ARM
         Same logic: rotated by π/2 around X to start
         horizontal, but on the right side.
         ============================================================ -->
    <link name="right_arm">
        <visual>
            <geometry>
                <box size="0.08 0.08 0.3"/>
            </geometry>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <material name="r2d2_silver"/>
        </visual>
    </link>

    <joint name="joint_right_arm" type="revolute">
        <parent link="body"/>
        <child link="right_arm"/>
        <origin xyz="0 0.25 0.05" rpy="-1.5708 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="-1.0" upper="1.0" effort="10" velocity="10"/>
    </joint>


    <!-- ============================================================
         ANTENNA (decorative detail)
         ============================================================ -->
    <link name="antenna">
        <visual>
            <geometry>
                <cylinder radius="0.015" length="0.15"/>
            </geometry>
            <origin xyz="0 0 0.075" rpy="0 0 0"/>
            <material name="r2d2_red"/>
        </visual>
    </link>

    <joint name="head_to_antenna" type="fixed">
        <parent link="head"/>
        <child link="antenna"/>
        <origin xyz="0 0 0.18" rpy="0 0 0"/>
    </joint>

</robot>
